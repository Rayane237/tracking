# Frontend Environment Variables

# API Configuration
# Development: http://localhost:5001/api
# Production: https://dubai-global-express-api-production.up.railway.app/api
VITE_API_URL=https://dubai-global-express-api-production.up.railway.app/api

# Application Name
VITE_APP_NAME=Dubai Global Express

# Notes for Vercel:
# 1. Set VITE_API_URL to your Railway backend URL
# 2. All variables must start with VITE_ to be accessible in the browser
# 3. Add these in Vercel Dashboard → Settings → Environment Variables

